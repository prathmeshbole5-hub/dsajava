



import java.util.Scanner;

public class forloop {
    public static void main(String[] args) {
       Scanner sc = new Scanner(System.in);
        System.out.println("enter the number :  ");
        int n= sc.nextInt() ;

        for(int i=0;i<=n;i=i+1){
            System.out.println(i);
        }

    }
}
